{
  "name": "@chronary/schemas",
  "version": "0.1.3",
  "description": "Zod schemas and types for the Chronary calendar API, including webhook event payload validation",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./events": {
      "import": {
        "types": "./dist/events.d.ts",
        "default": "./dist/events.js"
      },
      "require": {
        "types": "./dist/events.d.cts",
        "default": "./dist/events.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "chronary",
    "zod",
    "schemas",
    "webhook",
    "calendar-api",
    "validation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Chronary/chronary-schemas"
  },
  "homepage": "https://docs.chronary.ai",
  "bugs": {
    "url": "https://github.com/Chronary/chronary-schemas/issues"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
